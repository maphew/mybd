#!/usr/bin/env bash
# verify-next - run one queued local verification job.
#
# Usage:
#   scripts/verify-next [bd-id-or-pr-num]
#
# Environment:
#   VERIFY_TIMEOUT=45m
#   VERIFY_WORKTREE_BASE=/var/home/matt/dev/mybd/.worktrees/beads
#   VERIFY_LOG_DIR=/var/home/matt/dev/mybd/.worktrees/beads/.verify-logs
#   VERIFY_KEEP_WORKTREE=failed   # always | failed | never
#   VERIFY_MARK_STALE=1           # 1 = mark unreachable-HEAD jobs stale; 0 = just skip

set -euo pipefail
. "$(dirname "$0")/_tri-lib.sh"
tri_require bd git jq bash

usage() {
  sed -n '2,12p' "$0" | sed 's/^# \{0,1\}//'
}

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  usage
  exit 0
fi

VERIFY_TIMEOUT="${VERIFY_TIMEOUT:-45m}"
VERIFY_WORKTREE_BASE="${VERIFY_WORKTREE_BASE:-$TRI_PROJECT_ROOT/.worktrees/beads}"
VERIFY_LOG_DIR="${VERIFY_LOG_DIR:-$VERIFY_WORKTREE_BASE/.verify-logs}"
VERIFY_KEEP_WORKTREE="${VERIFY_KEEP_WORKTREE:-failed}"
# When a queued job's recorded HEAD is no longer reachable from the bd-main
# clone (branch deleted/rebased after enqueue), mark it stale and move on rather
# than aborting the whole run, so newer valid jobs behind it still get a turn
# (mybd-l7tp). Set VERIFY_MARK_STALE=0 to skip such jobs without mutating bd.
VERIFY_MARK_STALE="${VERIFY_MARK_STALE:-1}"

# cgo link fix (mybd-4sw1): the verify command runs under a login shell, whose
# profile can put linuxbrew gcc ahead of system gcc. That gcc cannot find
# Fedora's glibc startup objects (Scrt1.o/crti.o), so every cgo test link fails
# while pure-Go packages pass. Pin CC/CXX to the system toolchain (honored by
# cgo regardless of PATH). Use single-dash defaults so an explicit empty value
# (VERIFY_CC=) disables the pin; the pin is skipped when the binary is absent
# (e.g. macOS), making this a no-op on boxes that don't need it.
VERIFY_CC="${VERIFY_CC-/usr/bin/gcc}"
VERIFY_CXX="${VERIFY_CXX-/usr/bin/g++}"

verify_env=()
[[ -n "$VERIFY_CC" && -x "$VERIFY_CC" ]] && verify_env+=("CC=$VERIFY_CC")
[[ -n "$VERIFY_CXX" && -x "$VERIFY_CXX" ]] && verify_env+=("CXX=$VERIFY_CXX")

if [[ $# -gt 1 ]]; then
  usage >&2
  exit 2
fi

# Load a queued job's verify_* metadata into the shared globals.
load_job() {
  local bd_id="$1"
  issue_json="$(bd show "$bd_id" --json)"
  state="$(jq -r '.[0].metadata.verify_state // empty' <<<"$issue_json")"
  head_sha="$(jq -r '.[0].metadata.verify_head // empty' <<<"$issue_json")"
  verify_cmd="$(jq -r '.[0].metadata.verify_cmd | if . == null or . == "" then "make test" else tostring end' <<<"$issue_json")"
  branch="$(jq -r '.[0].metadata.verify_branch | if . == null or . == "" then "unknown" else tostring end' <<<"$issue_json")"
  [[ -n "$verify_cmd" ]] || verify_cmd="make test"
}

# True when $1 names a commit object reachable from the bd-main clone.
head_reachable() {
  local sha="$1"
  [[ -n "$sha" ]] || return 1
  git -C "$TRI_BD_MAIN" cat-file -e "$sha^{commit}" 2>/dev/null
}

# Mark a job whose recorded HEAD is unreachable as stale (same bd-write
# mechanism as finish()), so the FIFO loop can move past it. With
# VERIFY_MARK_STALE=0 the bd record is left untouched and the job is only
# skipped for this run.
mark_stale() {
  local bd_id="$1" sha="$2" reason
  reason="head-unreachable: ${sha:-<none>} not visible from $TRI_BD_MAIN"
  if [[ "$VERIFY_MARK_STALE" != "1" ]]; then
    echo "Skipping $bd_id: $reason (not marking; VERIFY_MARK_STALE=$VERIFY_MARK_STALE)." >&2
    return 0
  fi
  local finished_at
  finished_at="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
  bd update "$bd_id" \
    --set-metadata verify_state=stale \
    --set-metadata "verify_result=$reason" \
    --set-metadata "verify_finished_at=$finished_at" \
    >/dev/null
  tri_log_note "$bd_id" "verification skipped (stale): $reason"
  echo "Skipped $bd_id: $reason (marked stale)." >&2
}

if [[ $# -eq 1 ]]; then
  BD_ID="$(tri_resolve_bd_id "$1")"
  load_job "$BD_ID"
  [[ "$state" == "queued" ]] || tri_die "$BD_ID verify_state is '$state', not queued"
  [[ -n "$head_sha" ]] || tri_die "$BD_ID has no verify_head metadata"
  if ! head_reachable "$head_sha"; then
    mark_stale "$BD_ID" "$head_sha"
    exit 0
  fi
else
  # FIFO auto-select. Skip (and mark stale) jobs whose recorded HEAD is no
  # longer reachable from bd-main so they cannot jam newer valid jobs behind
  # them in the queue (mybd-l7tp).
  # Strip any trailing CR: on Windows the bd/jq pipeline can emit CRLF
  # line terminators, and mapfile -t only strips LF, leaving a trailing \r
  # on each id that makes bd reject it (mybd-5tz0 papercut).
  mapfile -t queued_ids < <(
    bd list --limit 0 --json \
      | jq -r '[.[] | select((.metadata.verify_state // "") == "queued")]
               | sort_by((.priority // 99), (.updated_at // ""))
               | .[].id' \
      | tr -d '\r'
  )
  if [[ ${#queued_ids[@]} -eq 0 ]]; then
    echo "No queued verification jobs."
    exit 0
  fi
  BD_ID=""
  for cand in "${queued_ids[@]}"; do
    load_job "$cand"
    # State may have changed between listing and load (another runner); requeue
    # check keeps us honest.
    [[ "$state" == "queued" ]] || continue
    if ! head_reachable "$head_sha"; then
      mark_stale "$cand" "$head_sha"
      continue
    fi
    BD_ID="$cand"
    break
  done
  if [[ -z "$BD_ID" ]]; then
    echo "No queued verification jobs with a reachable HEAD."
    exit 0
  fi
fi

mkdir -p "$VERIFY_WORKTREE_BASE" "$VERIFY_LOG_DIR"

short="${head_sha:0:12}"
stamp="$(date -u +%Y%m%dT%H%M%SZ)"
started_at="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
runner="$(hostname -s 2>/dev/null || echo unknown):$$"
verify_wt="$VERIFY_WORKTREE_BASE/verify-$BD_ID-$short-$stamp"
log="$VERIFY_LOG_DIR/$BD_ID-$short-$stamp.log"

bd update "$BD_ID" \
  --set-metadata verify_state=running \
  --set-metadata "verify_started_at=$started_at" \
  --set-metadata verify_finished_at= \
  --set-metadata "verify_runner=$runner" \
  --set-metadata "verify_log=$log" \
  --set-metadata "verify_result=running" \
  >/dev/null

tri_log_note "$BD_ID" "verification running: runner=$runner head=$short log=$log"

finish() {
  local final_state="$1"
  local result="$2"
  local finished_at
  finished_at="$(date -u +%Y-%m-%dT%H:%M:%SZ)"

  bd update "$BD_ID" \
    --set-metadata "verify_state=$final_state" \
    --set-metadata "verify_result=$result" \
    --set-metadata "verify_finished_at=$finished_at" \
    --set-metadata "verify_worktree=$verify_wt" \
    >/dev/null

  tri_log_note "$BD_ID" "verification $final_state: head=$short result=$result log=$log"
}

{
  echo "verification job"
  echo "  bead:      $BD_ID"
  echo "  head:      $head_sha"
  echo "  branch:    $branch"
  echo "  command:   $verify_cmd"
  echo "  compiler:  ${verify_env[*]:-(system default)}"
  echo "  runner:    $runner"
  echo "  started:   $started_at"
  echo "  worktree:  $verify_wt"
  echo
  echo "creating clean verification worktree..."
} >"$log"

if ! git -C "$TRI_BD_MAIN" worktree add --detach "$verify_wt" "$head_sha" >>"$log" 2>&1; then
  finish failed "worktree-add-failed"
  echo "Verification failed for $BD_ID while creating worktree. Log: $log" >&2
  exit 1
fi

{
  echo
  echo "running command with timeout $VERIFY_TIMEOUT..."
  echo
} >>"$log"

set +e
if command -v timeout >/dev/null 2>&1; then
  (cd "$verify_wt" && timeout "$VERIFY_TIMEOUT" env ${verify_env[@]+"${verify_env[@]}"} bash -lc "$verify_cmd") >>"$log" 2>&1
else
  (cd "$verify_wt" && env ${verify_env[@]+"${verify_env[@]}"} bash -lc "$verify_cmd") >>"$log" 2>&1
fi
exit_code=$?
set -e

{
  echo
  echo "command exit code: $exit_code"
  echo
  echo "post-run git status:"
  git -C "$verify_wt" status --short || true
} >>"$log"

if [[ "$exit_code" -eq 0 ]]; then
  finish passed "exit=0"
  case "$VERIFY_KEEP_WORKTREE" in
    always) ;;
    failed|never)
      {
        echo
        echo "removing verification worktree after pass..."
        git -C "$TRI_BD_MAIN" worktree remove --force "$verify_wt"
      } >>"$log" 2>&1 || true
      ;;
    *) tri_die "unknown VERIFY_KEEP_WORKTREE=$VERIFY_KEEP_WORKTREE (expected always, failed, never)" ;;
  esac
  echo "Verification passed for $BD_ID. Log: $log"
  exit 0
fi

finish failed "exit=$exit_code"
case "$VERIFY_KEEP_WORKTREE" in
  always|failed) ;;
  never)
    {
      echo
      echo "removing verification worktree after failure..."
      git -C "$TRI_BD_MAIN" worktree remove --force "$verify_wt"
    } >>"$log" 2>&1 || true
    ;;
  *) tri_die "unknown VERIFY_KEEP_WORKTREE=$VERIFY_KEEP_WORKTREE (expected always, failed, never)" ;;
esac

echo "Verification failed for $BD_ID with exit=$exit_code. Log: $log" >&2
exit "$exit_code"
