#!/usr/bin/env bash
# check-beads-config - fail fast if bd is pointed at the wrong local DB.

set -euo pipefail

QUIET=0
FIX=0
while [[ $# -gt 0 ]]; do
  case "$1" in
    --quiet) QUIET=1; shift;;
    --fix) FIX=1; shift;;
    -h|--help)
      sed -n '2,30p' "$0" | sed 's/^# \{0,1\}//'
      exit 0
      ;;
    *) echo "check-beads-config: unknown arg: $1" >&2; exit 2;;
  esac
done

ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
BEADS_DIR="$ROOT/.beads"
CONFIG="$BEADS_DIR/config.yaml"
METADATA="$BEADS_DIR/metadata.json"
EXPECTED_DB="${MYBD_EXPECTED_BEADS_DB:-mybd}"
# Canonical remote is maphew/mybd. Both Git transports are accepted because the
# live embedded Dolt DB uses SSH while older guard text assumed HTTPS; forcing a
# single string caused repeated dolt_database flip-flops.
EXPECTED_REMOTE_HTTPS="git+https://github.com/maphew/mybd.git"
EXPECTED_REMOTE_SSH="git+ssh://git@github.com/maphew/mybd.git"

remote_matches_expected() {
  local url="$1"
  if [[ -n "${MYBD_EXPECTED_BEADS_REMOTE:-}" ]]; then
    [[ "$url" == "$MYBD_EXPECTED_BEADS_REMOTE" ]]
    return
  fi
  [[ "$url" == "$EXPECTED_REMOTE_HTTPS" || "$url" == "$EXPECTED_REMOTE_SSH" ]]
}

expected_remote_label() {
  if [[ -n "${MYBD_EXPECTED_BEADS_REMOTE:-}" ]]; then
    printf '%s' "$MYBD_EXPECTED_BEADS_REMOTE"
  else
    printf '%s' "$EXPECTED_REMOTE_HTTPS or $EXPECTED_REMOTE_SSH"
  fi
}

die() { echo "check-beads-config: $*" >&2; exit 1; }
say() { [[ "$QUIET" == 1 ]] || printf '%s\n' "$*"; }

command -v jq >/dev/null || die "jq not on PATH"
command -v dolt >/dev/null || die "dolt not on PATH"
[[ -f "$CONFIG" ]] || die "missing $CONFIG"
[[ -f "$METADATA" ]] || die "missing $METADATA"

metadata_backend="$(jq -r '.backend // empty' "$METADATA")"
metadata_database="$(jq -r '.database // empty' "$METADATA")"
active_db="$(jq -r '.dolt_database // empty' "$METADATA")"

count_issues() {
  local db_name="$1"
  local db_dir="$BEADS_DIR/embeddeddolt/$db_name"
  [[ -d "$db_dir/.dolt" ]] || return 1
  (
    cd "$db_dir"
    dolt sql -r json -q 'select count(*) as n from issues' 2>/dev/null \
      | jq -r '.rows[0].n // empty'
  )
}

remote_url() {
  local db_name="$1"
  local db_dir="$BEADS_DIR/embeddeddolt/$db_name"
  [[ -d "$db_dir/.dolt" ]] || return 1
  (
    cd "$db_dir"
    dolt remote -v 2>/dev/null | awk '$1 == "origin" { print $2; exit }'
  )
}

repair_metadata_database() {
  local tmp
  tmp="$(mktemp "${METADATA}.tmp.XXXXXX")"
  jq --arg db "$EXPECTED_DB" '.dolt_database = $db' "$METADATA" > "$tmp"
  mv -f "$tmp" "$METADATA"
}

failures=0
report_failure() {
  failures=$((failures + 1))
  echo "check-beads-config: $*" >&2
}

if [[ "$metadata_backend" != "dolt" || "$metadata_database" != "dolt" ]]; then
  report_failure "metadata backend/database should both be dolt, got backend=$metadata_backend database=$metadata_database"
fi

if [[ "$active_db" != "$EXPECTED_DB" ]]; then
  report_failure "metadata points at dolt_database=$active_db; expected $EXPECTED_DB"
fi

if grep -Eq '^[[:space:]]*no-db:[[:space:]]*true([[:space:]]*(#.*)?)?$' "$CONFIG"; then
  report_failure "config enables no-db:true; mybd must use the embedded Dolt database"
fi

expected_count="$(count_issues "$EXPECTED_DB" || true)"
expected_remote="$(remote_url "$EXPECTED_DB" || true)"
active_count=""
if [[ -n "$active_db" ]]; then
  active_count="$(count_issues "$active_db" || true)"
fi

if [[ -z "$expected_count" ]]; then
  report_failure "expected database $EXPECTED_DB is missing or unreadable under .beads/embeddeddolt"
elif [[ "$expected_count" == "0" ]]; then
  report_failure "expected database $EXPECTED_DB has zero issues"
fi

if [[ -n "$active_db" && "$active_db" != "$EXPECTED_DB" && -n "$active_count" && "$active_count" == "0" && -n "$expected_count" && "$expected_count" != "0" ]]; then
  report_failure "active database $active_db is empty while $EXPECTED_DB has $expected_count issues"
fi

expected_remote_ok=0
if [[ -n "$expected_remote" ]] && remote_matches_expected "$expected_remote"; then
  expected_remote_ok=1
fi

if [[ -n "$expected_remote" && "$expected_remote_ok" != 1 ]]; then
  report_failure "expected database $EXPECTED_DB origin remote is $expected_remote; expected $(expected_remote_label)"
fi

# --- hooksPath drift (warn-only; never changes this script's exit code) ---
# `bd hooks install --beads` is known to flip core.hooksPath to .beads/hooks,
# silently deactivating the composed .githooks set (root-commit guard,
# scripts/pre-commit-beads-config, Entire CLI hooks, and all five bd hook
# events). Detect and, with --fix, repair that drift. This runs unconditionally
# and does not feed into $failures, so it never changes the exit code above.
EXPECTED_HOOKS_PATH=".githooks"
current_hooks_path="$(git -C "$ROOT" config --get core.hooksPath 2>/dev/null || true)"
if [[ "$current_hooks_path" == "$EXPECTED_HOOKS_PATH" ]]; then
  say "beads config ok: core.hooksPath is $EXPECTED_HOOKS_PATH"
else
  if [[ "$FIX" == 1 ]]; then
    git -C "$ROOT" config core.hooksPath "$EXPECTED_HOOKS_PATH"
    say "beads config repaired: core.hooksPath set to $EXPECTED_HOOKS_PATH (was ${current_hooks_path:-"(unset)"})"
  else
    echo "check-beads-config: warning: core.hooksPath is ${current_hooks_path:-"(unset)"}; expected $EXPECTED_HOOKS_PATH" >&2
    echo "check-beads-config: warning: 'bd hooks install --beads' is known to flip this and deactivate the composed .githooks set" >&2
    echo "check-beads-config: warning: fix with: git config core.hooksPath $EXPECTED_HOOKS_PATH (or re-run with --fix)" >&2
  fi
fi

if [[ "$failures" -gt 0 ]]; then
  if [[ "$FIX" == 1 ]]; then
    if [[ "$metadata_backend" == "dolt" \
       && "$metadata_database" == "dolt" \
       && "$active_db" != "$EXPECTED_DB" \
       && -n "$expected_count" \
       && "$expected_count" != "0" \
       && "$expected_remote_ok" == "1" \
       && ( -z "$active_count" || "$active_count" == "0" ) ]]; then
      repair_metadata_database
      say "beads config repaired: .beads/metadata.json dolt_database=$EXPECTED_DB ($expected_count issues, origin $expected_remote)"
      exit 0
    fi
    echo "check-beads-config: --fix refused; database state is ambiguous or canonical remote/count checks failed" >&2
  fi
  echo "check-beads-config: remedy: keep .beads/metadata.json dolt_database=$EXPECTED_DB, do not restore stale no-db:true config, and do not point at the empty beads bootstrap database" >&2
  echo "check-beads-config: if both databases contain issues, export both before repair and reconcile manually" >&2
  exit 1
fi

say "beads config ok: active database $EXPECTED_DB ($expected_count issues)"
