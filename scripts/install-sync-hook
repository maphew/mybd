#!/usr/bin/env bash
# install-sync-hook — retired JSONL-through-git sync hook installer.
#
# mybd syncs issue state with `bd dolt push` / `bd dolt pull`. JSONL is kept
# only as export/backup/viewer data, so no git hook should import it after pull.

set -euo pipefail

echo "install-sync-hook: retired; use bd dolt push / bd dolt pull for mybd sync"
