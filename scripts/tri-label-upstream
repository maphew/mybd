#!/usr/bin/env bash
# tri-label-upstream — apply the upstream 'triaged' label for a bd external_ref.
#
# Accepts either:
#   --external-ref=gh-pr-NNNN / gh-iss-NNNN
# or a full issue JSON document on stdin (used by .beads/hooks/on_close).
#
# Usage:
#   tri-label-upstream --external-ref=gh-pr-1234

set -euo pipefail

UPSTREAM="${TRI_UPSTREAM:-gastownhall/beads}"
EXTERNAL_REF=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --external-ref=*) EXTERNAL_REF="${1#--external-ref=}"; shift;;
    --external-ref) EXTERNAL_REF="$2"; shift 2;;
    -h|--help)
      sed -n '2,9p' "$0" | sed 's/^# \{0,1\}//'
      exit 0
      ;;
    *)
      echo "tri-label-upstream: unknown arg: $1" >&2
      exit 2
      ;;
  esac
done

command -v gh >/dev/null || { echo "tri-label-upstream: gh not on PATH" >&2; exit 127; }
command -v jq >/dev/null || { echo "tri-label-upstream: jq not on PATH" >&2; exit 127; }

if [[ -z "$EXTERNAL_REF" && ! -t 0 ]]; then
  EXTERNAL_REF="$(jq -r '.external_ref // empty' < /dev/stdin 2>/dev/null || true)"
fi

if [[ -z "$EXTERNAL_REF" ]]; then
  exit 0
fi

if [[ ! "$EXTERNAL_REF" =~ ^gh-(pr|iss)-([0-9]+)$ ]]; then
  exit 0
fi

kind="${BASH_REMATCH[1]}"
num="${BASH_REMATCH[2]}"

if [[ "$kind" == "pr" ]]; then
  gh pr edit "$num" --repo "$UPSTREAM" --add-label triaged >/dev/null
else
  gh issue edit "$num" --repo "$UPSTREAM" --add-label triaged >/dev/null
fi
