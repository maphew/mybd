#!/usr/bin/env bash
# tri-pull — pull untriaged open items from upstream gastownhall/beads into
# bd as triage stubs. Idempotent: skips items already mirrored.
#
# Usage:
#   tri-pull               # pull issues + PRs (default limit 100 each)
#   tri-pull --limit 50    # cap per-stream
#   tri-pull --issues-only
#   tri-pull --prs-only
#   tri-pull --dry-run     # show what would be created, no writes
#
# Each stub:
#   external-ref: gh-pr-NNNN / gh-iss-NNNN  (machine-readable upstream link)
#   title:        "<upstream title>"        (kind+number visible via show)
#   description:  URL, author, dates, labels, status
#   priority:     heuristic from title/body/size/age/review state
#   type:         bug/feature/task heuristic from conventional-commit prefix

set -euo pipefail

UPSTREAM="${TRI_UPSTREAM:-gastownhall/beads}"
LIMIT=100
DO_ISSUES=1
DO_PRS=1
DRY_RUN=0

while [[ $# -gt 0 ]]; do
  case "$1" in
    --limit) LIMIT="$2"; shift 2;;
    --limit=*) LIMIT="${1#--limit=}"; shift;;
    --issues-only) DO_PRS=0; shift;;
    --prs-only) DO_ISSUES=0; shift;;
    --dry-run) DRY_RUN=1; shift;;
    -h|--help) sed -n '2,18p' "$0" | sed 's/^# \{0,1\}//'; exit 0;;
    *) echo "tri-pull: unknown flag: $1" >&2; exit 2;;
  esac
done

command -v bd >/dev/null || { echo "tri-pull: bd not on PATH" >&2; exit 127; }
command -v gh >/dev/null || { echo "tri-pull: gh not on PATH" >&2; exit 127; }
command -v jq >/dev/null || { echo "tri-pull: jq not on PATH" >&2; exit 127; }

issues_json="$(mktemp)"
prs_json="$(mktemp)"
trap 'rm -f "$issues_json" "$prs_json"' EXIT

declare -A REF_TO_ID=()
declare -A KNOWN_PR_NUMS=()
declare -A KNOWN_ISS_NUMS=()
declare -A DEP_SEEN=()

refresh_ref_cache() {
  REF_TO_ID=()
  KNOWN_PR_NUMS=()
  KNOWN_ISS_NUMS=()

  while IFS=$'\t' read -r id ref; do
    [[ -z "${id:-}" || -z "${ref:-}" ]] && continue
    REF_TO_ID["$ref"]="$id"
    if [[ "$ref" =~ ^gh-pr-([0-9]+)$ ]]; then
      KNOWN_PR_NUMS["${BASH_REMATCH[1]}"]=1
    elif [[ "$ref" =~ ^gh-iss-([0-9]+)$ ]]; then
      KNOWN_ISS_NUMS["${BASH_REMATCH[1]}"]=1
    fi
  done < <(
    bd list --status=open --status=in_progress --status=closed --status=blocked --status=deferred --limit 0 --json 2>/dev/null \
      | jq -r '.[] | select(.external_ref != null and (.external_ref | test("^gh-(pr|iss)-[0-9]+$"))) | [.id, .external_ref] | @tsv'
  )
}

register_json_refs() {
  local kind="$1" file="$2" num
  while IFS= read -r num; do
    [[ -z "$num" ]] && continue
    if [[ "$kind" == "pr" ]]; then
      KNOWN_PR_NUMS["$num"]=1
    else
      KNOWN_ISS_NUMS["$num"]=1
    fi
  done < <(jq -r '.[].number' "$file" 2>/dev/null || true)
}

is_mirrored() {
  local ref="$1"
  [[ -n "${REF_TO_ID[$ref]:-}" ]]
}

infer_type() {
  local title="${1,,}"
  case "$title" in
    fix\(*|fix:*|bug\(*|bug:*) echo "bug" ;;
    feat\(*|feat:*) echo "feature" ;;
    *) echo "task" ;;
  esac
}

created_epoch() {
  local created="$1"
  date -d "$created" +%s 2>/dev/null || echo 0
}

infer_priority() {
  local kind="$1" title="$2" body="$3" author="$4" created="$5" labels="$6" draft="$7" additions="$8" deletions="$9" review="${10}" merge_state="${11}"
  local total age_days now created_ts lower_title lower_body lower_labels type

  total=$((additions + deletions))
  now="$(date +%s)"
  created_ts="$(created_epoch "$created")"
  age_days=999
  if [[ "$created_ts" -gt 0 ]]; then
    age_days=$(( (now - created_ts) / 86400 ))
  fi

  lower_title="${title,,}"
  lower_body="${body,,}"
  lower_labels=",${labels,,},"
  type="$(infer_type "$title")"

  if [[ "$author" == "app/dependabot" ]] || [[ "$draft" == "true" ]]; then
    echo 4
    return
  fi
  if [[ "$merge_state" == "DIRTY" && "$age_days" -ge 7 ]]; then
    echo 4
    return
  fi
  if [[ "$total" -ge 1600 && "$age_days" -ge 14 ]]; then
    echo 4
    return
  fi
  if [[ "$age_days" -ge 45 && "$total" -ge 600 ]]; then
    echo 4
    return
  fi

  if [[ "$type" == "bug" ]] || [[ "$lower_title" == perf\(* || "$lower_title" == perf:* ]] || [[ "$lower_labels" == *",bug,"* ]] || [[ "$lower_labels" == *",regression,"* ]]; then
    if [[ "$lower_title" == *security* ]] || [[ "$lower_title" == *panic* ]] || [[ "$lower_title" == *crash* ]] || [[ "$lower_title" == *corrupt* ]] || [[ "$lower_body" == *"data loss"* ]]; then
      if [[ "$age_days" -le 7 ]]; then
        echo 0
        return
      fi
    fi
    if [[ "$total" -le 250 && "$age_days" -le 3 ]]; then
      echo 0
      return
    fi
    if [[ "$total" -le 500 && "$age_days" -le 14 && "$merge_state" != "DIRTY" ]]; then
      echo 1
      return
    fi
    if [[ "$total" -le 1000 ]]; then
      echo 2
      return
    fi
  fi

  if [[ "$type" == "feature" ]]; then
    if [[ "$total" -le 250 && "$age_days" -le 14 ]]; then
      echo 2
      return
    fi
  fi

  if [[ "$kind" == "iss" && "$type" == "bug" && "$age_days" -le 7 ]]; then
    echo 1
    return
  fi

  echo 3
}

build_desc() {
  local kind="$1" url="$2" author="$3" created="$4" labels="$5" status_lines="$6"
  local kind_label

  case "$kind" in
    pr) kind_label="PR" ;;
    iss) kind_label="Issue" ;;
    *) kind_label="Item" ;;
  esac

  printf 'Upstream %s: %s\nAuthor: %s\nCreated: %s\nLabels: %s%s\n\nTriage decision: close (won'\''t engage / dupe / out of scope), defer (revisit), claim (real work + flesh out), or human (need maintainer call).\nUse: scripts/tri-close <bd-id> [--reason=...]   (closes bd + applies '\''triaged'\'' label upstream)' \
    "$kind_label" "$url" "$author" "$created" "${labels:-(none)}" "${status_lines:+
$status_lines}"
}

mirror_one() {
  local kind="$1" num="$2" title="$3" body="$4" url="$5" author="$6" created="$7" labels="$8" draft="$9" additions="${10}" deletions="${11}" review="${12}" merge_state="${13}"
  local ref="gh-${kind}-${num}"

  if is_mirrored "$ref"; then
    return 1
  fi

  local prio type status_lines desc total
  prio="$(infer_priority "$kind" "$title" "$body" "$author" "$created" "$labels" "$draft" "$additions" "$deletions" "$review" "$merge_state")"
  type="$(infer_type "$title")"

  total=$((additions + deletions))
  status_lines=""
  if [[ "$kind" == "pr" ]]; then
    [[ "$draft" == "true" ]] && status_lines+="Status: DRAFT"$'\n'
    [[ -n "$review" && "$review" != "null" ]] && status_lines+="Review: $review"$'\n'
    [[ -n "$merge_state" && "$merge_state" != "null" ]] && status_lines+="Merge state: $merge_state"$'\n'
    status_lines+="Size: +$additions/-$deletions ($total lines)"
  fi
  desc="$(build_desc "$kind" "$url" "$author" "$created" "$labels" "$status_lines")"

  if [[ "$DRY_RUN" == 1 ]]; then
    printf '  WOULD create %s P%d type=%s: %s\n' "$ref" "$prio" "$type" "$title"
    return 0
  fi

  bd create \
    --title="$title" \
    --description="$desc" \
    --external-ref="$ref" \
    --type="$type" \
    --priority="$prio" >/dev/null

  printf '  created %s P%d type=%s: %s\n' "$ref" "$prio" "$type" "$title"
  return 0
}

resolve_ref_num() {
  local num="$1"
  if [[ -n "${KNOWN_PR_NUMS[$num]:-}" ]]; then
    echo "gh-pr-$num"
    return 0
  fi
  if [[ -n "${KNOWN_ISS_NUMS[$num]:-}" ]]; then
    echo "gh-iss-$num"
    return 0
  fi
  return 1
}

maybe_add_dep() {
  local child_ref="$1" parent_ref="$2" why="$3"
  local child_id parent_id key

  [[ "$child_ref" == "$parent_ref" ]] && return
  child_id="${REF_TO_ID[$child_ref]:-}"
  parent_id="${REF_TO_ID[$parent_ref]:-}"
  [[ -z "$child_id" || -z "$parent_id" ]] && return

  key="$child_id|$parent_id"
  [[ -n "${DEP_SEEN[$key]:-}" ]] && return
  DEP_SEEN["$key"]=1

  if [[ "$DRY_RUN" == 1 ]]; then
    echo "  WOULD link $child_id -> $parent_id ($why)"
    return
  fi

  if bd dep add "$child_id" "$parent_id" >/dev/null 2>&1; then
    echo "  linked $child_id -> $parent_id ($why)"
    return
  fi

  if ! bd show "$child_id" --json 2>/dev/null | jq -e --arg dep "$parent_id" '.[0].dependencies // [] | any(.depends_on_id == $dep)' >/dev/null; then
    echo "  ! failed to link $child_id -> $parent_id ($why)" >&2
  fi
}

link_relationships() {
  local item body child_ref num parent_num parent_ref issue_num issue_ref closing_refs

  [[ "$DO_PRS" == 1 ]] || return
  echo "Linking related upstream items..."

  while IFS= read -r item; do
    [[ -z "${item:-}" ]] && continue
    num="$(jq -r '.number' <<<"$item")"
    body="$(jq -r '.body // ""' <<<"$item")"
    closing_refs="$(jq -r '[.closingIssuesReferences[].number] | join(",")' <<<"$item")"
    child_ref="gh-pr-$num"

    while IFS= read -r parent_num; do
      [[ -z "${parent_num:-}" ]] && continue
      parent_ref="$(resolve_ref_num "$parent_num" || true)"
      [[ -n "$parent_ref" ]] && maybe_add_dep "$child_ref" "$parent_ref" "stacked/dependent upstream PR text"
    done < <(printf '%s\n' "$body" | grep -oiE '(stacks on|stacked on|depends on|blocked by) #[0-9]+' | grep -oE '[0-9]+' || true)

    while IFS= read -r issue_num; do
      [[ -z "${issue_num:-}" ]] && continue
      issue_ref="gh-iss-$issue_num"
      maybe_add_dep "$issue_ref" "$child_ref" "PR closes/fixes upstream issue"
    done < <(printf '%s\n' "$closing_refs" | tr ',' '\n' | sed 's/^[[:space:]]*//;s/[[:space:]]*$//' | grep -E '^[0-9]+$' || true)
  done < <(jq -c '.[] | select((([.labels[].name] | index("triaged")) | not))' "$prs_json")
}

warn_closed_without_label() {
  local checked=0 warned=0
  local bd_id closed_at ref parsed kind num json labels

  echo "Checking recently closed triage stubs for missing upstream triaged labels..."
  while IFS=$'\t' read -r bd_id closed_at ref; do
    [[ -z "${ref:-}" ]] && continue
    parsed="$(sed -nE 's/^gh-(pr|iss)-([0-9]+)$/\1 \2/p' <<<"$ref")"
    [[ -z "$parsed" ]] && continue
    read -r kind num <<<"$parsed"

    if [[ "$kind" == "pr" ]]; then
      json="$(gh pr view "$num" --repo "$UPSTREAM" --json labels 2>/dev/null || true)"
    else
      json="$(gh issue view "$num" --repo "$UPSTREAM" --json labels 2>/dev/null || true)"
    fi
    [[ -z "$json" ]] && continue

    labels="$(jq -r '[.labels[].name] | join(",")' <<<"$json")"
    checked=$((checked + 1))
    if [[ ",${labels}," != *",triaged,"* ]]; then
      warned=$((warned + 1))
      echo "  warning: $bd_id ($ref, closed $closed_at) is closed locally but upstream still lacks the triaged label"
    fi
  done < <(
    bd list --status=closed --limit 0 --json \
      | jq -r '[.[] | select(.external_ref != null and (.external_ref | test("^gh-(pr|iss)-[0-9]+$"))) | {id, closed_at, external_ref}] | sort_by(.closed_at) | reverse | .[:20][] | [.id, .closed_at, .external_ref] | @tsv'
  )

  if [[ "$warned" -eq 0 ]]; then
    echo "  no recent plain-close label gaps detected ($checked checked)"
  else
    echo "  found $warned recent close(s) missing the upstream triaged label"
  fi
}

refresh_ref_cache

if [[ "$DO_ISSUES" == 1 ]]; then
  gh issue list --repo "$UPSTREAM" --state open --limit "$LIMIT" \
    --json number,title,url,author,createdAt,labels,body \
    >"$issues_json"
  register_json_refs "iss" "$issues_json"
fi

if [[ "$DO_PRS" == 1 ]]; then
  gh pr list --repo "$UPSTREAM" --state open --limit "$LIMIT" \
    --json number,title,url,author,createdAt,labels,isDraft,body,additions,deletions,reviewDecision,mergeStateStatus,closingIssuesReferences \
    >"$prs_json"
  register_json_refs "pr" "$prs_json"
fi

count_created=0
count_skipped=0

if [[ "$DO_ISSUES" == 1 ]]; then
  local_item=""
  echo "Pulling open issues from $UPSTREAM (no 'triaged' label, limit $LIMIT)..."
  while IFS= read -r local_item; do
    [[ -z "${local_item:-}" ]] && continue
    num="$(jq -r '.number' <<<"$local_item")"
    title="$(jq -r '.title' <<<"$local_item")"
    body="$(jq -r '.body // ""' <<<"$local_item")"
    url="$(jq -r '.url' <<<"$local_item")"
    author="$(jq -r '.author.login' <<<"$local_item")"
    created="$(jq -r '.createdAt' <<<"$local_item")"
    labels="$(jq -r '[.labels[].name] | join(",")' <<<"$local_item")"
    [[ -z "${num:-}" ]] && continue
    ref="gh-iss-${num}"
    if is_mirrored "$ref"; then
      count_skipped=$((count_skipped + 1))
      continue
    fi
    if mirror_one "iss" "$num" "$title" "$body" "$url" "$author" "$created" "$labels" "false" 0 0 "" ""; then
      count_created=$((count_created + 1))
    fi
  done < <(jq -c '.[] | select((([.labels[].name] | index("triaged")) | not))' "$issues_json")
fi

if [[ "$DO_PRS" == 1 ]]; then
  local_item=""
  echo "Pulling open PRs from $UPSTREAM (no 'triaged' label, limit $LIMIT)..."
  while IFS= read -r local_item; do
    [[ -z "${local_item:-}" ]] && continue
    num="$(jq -r '.number' <<<"$local_item")"
    title="$(jq -r '.title' <<<"$local_item")"
    body="$(jq -r '.body // ""' <<<"$local_item")"
    url="$(jq -r '.url' <<<"$local_item")"
    author="$(jq -r '.author.login' <<<"$local_item")"
    created="$(jq -r '.createdAt' <<<"$local_item")"
    labels="$(jq -r '[.labels[].name] | join(",")' <<<"$local_item")"
    is_draft="$(jq -r '.isDraft | tostring' <<<"$local_item")"
    additions="$(jq -r '.additions // 0' <<<"$local_item")"
    deletions="$(jq -r '.deletions // 0' <<<"$local_item")"
    review="$(jq -r '.reviewDecision // ""' <<<"$local_item")"
    merge_state="$(jq -r '.mergeStateStatus // ""' <<<"$local_item")"
    [[ -z "${num:-}" ]] && continue
    ref="gh-pr-${num}"
    if is_mirrored "$ref"; then
      count_skipped=$((count_skipped + 1))
      continue
    fi
    if mirror_one "pr" "$num" "$title" "$body" "$url" "$author" "$created" "$labels" "$is_draft" "$additions" "$deletions" "$review" "$merge_state"; then
      count_created=$((count_created + 1))
    fi
  done < <(jq -c '.[] | select((([.labels[].name] | index("triaged")) | not))' "$prs_json")
fi

refresh_ref_cache
link_relationships
warn_closed_without_label

echo
echo "Done. Created: $count_created, skipped (already mirrored): $count_skipped"
echo "Next: bd list --status=open --type=bug,feature,task | grep -E 'gh-(pr|iss)-' or run 'bd ready'"
