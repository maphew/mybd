#!/usr/bin/env python3
"""DEPRECATED (2026-07-07): Markdown -> self-contained HTML converter.

Reports are md-only now; the .html twin convention is retired. Read long
Markdown with `mdo` (https://github.com/maphew/mdo) instead. This script is
kept temporarily for anything that still calls it and will be removed once
nothing does.

It handles the GitHub-flavored subset the reports used: ATX headings, fenced
code, GFM tables, ordered/unordered lists, blockquotes, horizontal rules, and
inline code/bold/italic/links. Not a general Markdown engine.

Usage: scripts/md2html INPUT.md [OUTPUT.html]   (defaults to INPUT.html)
"""
import html
import re
import sys

CSS = """
  body { color:#202124; font:15px/1.6 system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;
         margin:32px auto; max-width:1120px; padding:0 24px; }
  h1,h2,h3,h4 { line-height:1.2; }
  h1 { font-size:1.7em; margin-bottom:0.2em; }
  h2 { margin-top:1.6em; border-bottom:1px solid #e0e0e0; padding-bottom:4px; }
  code,pre { font-family:ui-monospace,SFMono-Regular,Menlo,Consolas,monospace; }
  code { background:#f1f3f4; padding:1px 5px; border-radius:4px; font-size:0.9em; }
  pre { background:#f8f9fa; padding:12px 16px; border-radius:6px; overflow-x:auto; }
  pre code { background:none; padding:0; font-size:0.88em; }
  table { border-collapse:collapse; margin:12px 0; width:100%; }
  th,td { border:1px solid #dadce0; padding:6px 10px; text-align:left; font-size:0.92em; vertical-align:top; }
  th { background:#f1f3f4; }
  blockquote { border-left:3px solid #dadce0; margin:12px 0; padding:4px 16px; color:#5f6368; }
  a { color:#1a73e8; }
  ul,ol { margin:8px 0; }
  hr { border:none; border-top:1px solid #e0e0e0; margin:2em 0; }
  .sig { color:#5f6368; font-style:italic; }
"""


def inline(text):
    """Format inline markup on a single (already block-stripped) string."""
    spans = []

    def stash(m):
        spans.append(html.escape(m.group(1)))
        return f"\x00{len(spans) - 1}\x00"

    text = re.sub(r"`([^`]+)`", stash, text)          # protect inline code
    text = html.escape(text)
    text = re.sub(r"\[([^\]]+)\]\(([^)]+)\)",
                  lambda m: f'<a href="{html.escape(m.group(2), quote=True)}">{m.group(1)}</a>',
                  text)
    text = re.sub(r"\*\*(.+?)\*\*", r"<strong>\1</strong>", text)
    text = re.sub(r"(?<![\w*])\*([^*\n]+)\*(?![\w*])", r"<em>\1</em>", text)
    text = re.sub(r"(?<![\w_])_([^_\n]+)_(?![\w_])", r"<em>\1</em>", text)
    text = re.sub(r"\x00(\d+)\x00", lambda m: f"<code>{spans[int(m.group(1))]}</code>", text)
    return text


def is_table_sep(line):
    return bool(re.match(r"^\s*\|?[\s:|-]+\|?\s*$", line)) and "-" in line


def cells(line):
    line = line.strip()
    if line.startswith("|"):
        line = line[1:]
    if line.endswith("|"):
        line = line[:-1]
    return [c.strip() for c in line.split("|")]


def convert(md):
    lines = md.split("\n")
    out, i, n = [], 0, len(lines)
    while i < n:
        line = lines[i]
        s = line.strip()

        if s.startswith("```"):                         # fenced code
            i += 1
            buf = []
            while i < n and not lines[i].strip().startswith("```"):
                buf.append(lines[i])
                i += 1
            i += 1
            out.append("<pre><code>" + html.escape("\n".join(buf)) + "</code></pre>")
            continue

        if s.startswith("|") and i + 1 < n and is_table_sep(lines[i + 1]):  # table
            head = cells(line)
            i += 2
            body = []
            while i < n and lines[i].strip().startswith("|"):
                body.append(cells(lines[i]))
                i += 1
            t = ["<table>", "<thead><tr>"] + [f"<th>{inline(c)}</th>" for c in head] + ["</tr></thead>", "<tbody>"]
            for row in body:
                t.append("<tr>" + "".join(f"<td>{inline(c)}</td>" for c in row) + "</tr>")
            t += ["</tbody>", "</table>"]
            out.append("\n".join(t))
            continue

        m = re.match(r"^(#{1,6})\s+(.*)$", line)         # heading
        if m:
            lvl = len(m.group(1))
            out.append(f"<h{lvl}>{inline(m.group(2).strip())}</h{lvl}>")
            i += 1
            continue

        if re.match(r"^(---+|\*\*\*+)\s*$", s):          # hr
            out.append("<hr>")
            i += 1
            continue

        if s.startswith(">"):                            # blockquote
            buf = []
            while i < n and lines[i].strip().startswith(">"):
                buf.append(re.sub(r"^\s*>\s?", "", lines[i]))
                i += 1
            out.append("<blockquote>" + inline(" ".join(b for b in buf if b.strip())) + "</blockquote>")
            continue

        if re.match(r"^\s*[-*]\s+", line) or re.match(r"^\s*\d+\.\s+", line):  # list
            ordered = bool(re.match(r"^\s*\d+\.\s+", line))
            tag = "ol" if ordered else "ul"
            items = []
            pat = r"^\s*\d+\.\s+" if ordered else r"^\s*[-*]\s+"
            stop = re.compile(r"^\s*[-*]\s+|^\s*\d+\.\s+|^\s*(#{1,6}\s|>|```|\|)")
            while i < n and re.match(pat, lines[i]):
                item = re.sub(pat, "", lines[i])
                i += 1
                while i < n and lines[i].strip() and not stop.match(lines[i]) \
                        and not re.match(r"^(---+|\*\*\*+)\s*$", lines[i].strip()):
                    item += " " + lines[i].strip()       # fold wrapped continuation line
                    i += 1
                items.append(item)
            out.append(f"<{tag}>" + "".join(f"<li>{inline(it)}</li>" for it in items) + f"</{tag}>")
            continue

        if not s:                                        # blank
            i += 1
            continue

        buf = []                                         # paragraph
        while i < n and lines[i].strip() and not re.match(r"^(#{1,6}\s|>|```|\s*[-*]\s|\s*\d+\.\s)", lines[i]) \
                and not (lines[i].strip().startswith("|")) and not re.match(r"^(---+|\*\*\*+)\s*$", lines[i].strip()):
            buf.append(lines[i].strip())
            i += 1
        para = inline(" ".join(buf))
        cls = ' class="sig"' if para.startswith("<em>") and "on behalf of" in para else ""
        out.append(f"<p{cls}>{para}</p>")

    title = next((re.sub(r"^#\s+", "", l).strip() for l in lines if l.startswith("# ")), "Report")
    return (f"<!doctype html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n"
            f"<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n"
            f"<title>{html.escape(title)}</title>\n<style>{CSS}</style>\n</head>\n<body>\n"
            + "\n".join(out) + "\n</body>\n</html>\n")


def main():
    print("md2html is deprecated: reports are md-only now; "
          "read them with mdo (https://github.com/maphew/mdo)", file=sys.stderr)
    if len(sys.argv) < 2:
        sys.exit("usage: md2html INPUT.md [OUTPUT.html]")
    src = sys.argv[1]
    dst = sys.argv[2] if len(sys.argv) > 2 else re.sub(r"\.md$", "", src) + ".html"
    with open(src, encoding="utf-8") as f:
        md = f.read()
    with open(dst, "w", encoding="utf-8") as f:
        f.write(convert(md))
    print(dst)


if __name__ == "__main__":
    main()
