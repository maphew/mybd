#!/usr/bin/env bash
# tri-sync — mirror terminal upstream state into bd: close stubs whose
# upstream PR/issue is merged or closed.
#
# Complement to tri-pull (which brings new items *in*). Walks all open bd
# issues with gh-(pr|iss)-NNNN external_refs, queries gh for upstream state,
# and closes the bd stub if upstream is terminal. Captures merge SHA or
# close reason in the bd close reason for traceability.
#
# Does NOT apply the upstream 'triaged' label — that's tri-close's job for
# active triage decisions. Upstream items here are already terminal.
#
# Usage:
#   tri-sync                  # full pass: PRs + issues
#   tri-sync --prs-only       # PRs only
#   tri-sync --issues-only    # issues only
#   tri-sync --dry-run        # preview, no writes
#   tri-sync --limit N        # cap items processed (default: no cap)
#
# Idempotent: re-running closes only newly-terminal items.

set -euo pipefail

. "$(dirname "$0")/_tri-lib.sh"

UPSTREAM="$TRI_UPSTREAM"
DRY_RUN=0
LIMIT=0
DO_PRS=1
DO_ISSUES=1

while [[ $# -gt 0 ]]; do
  case "$1" in
    --dry-run) DRY_RUN=1; shift;;
    --prs-only) DO_ISSUES=0; shift;;
    --issues-only) DO_PRS=0; shift;;
    --limit) LIMIT="$2"; shift 2;;
    --limit=*) LIMIT="${1#--limit=}"; shift;;
    -h|--help) sed -n '2,21p' "$0" | sed 's/^# \{0,1\}//'; exit 0;;
    *) tri_die "unknown arg: $1";;
  esac
done

tri_require bd gh jq

# Emit one "<bd-id> <ref>" line per open bd issue with a gh-(pr|iss)-NNNN ref.
list_open_with_refs() {
  bd list --status=open --limit 0 --json 2>/dev/null \
    | jq -r '.[] | select(.external_ref != null and (.external_ref | test("^gh-(pr|iss)-[0-9]+$"))) | "\(.id) \(.external_ref)"'
}

closed_count=0
skipped_count=0
processed=0

while read -r bd_id ref; do
  [[ -z "$bd_id" ]] && continue
  if [[ "$LIMIT" -gt 0 && "$processed" -ge "$LIMIT" ]]; then
    break
  fi
  processed=$((processed + 1))

  parsed="$(tri_parse_ref "$ref")" || { skipped_count=$((skipped_count + 1)); continue; }
  read -r kind num <<<"$parsed"

  if [[ "$kind" == "pr" && "$DO_PRS" == 0 ]]; then continue; fi
  if [[ "$kind" == "iss" && "$DO_ISSUES" == 0 ]]; then continue; fi

  if [[ "$kind" == "pr" ]]; then
    json="$(gh pr view "$num" --repo "$UPSTREAM" --json state,mergedAt,mergeCommit,url 2>/dev/null || true)"
    [[ -z "$json" ]] && { echo "  ? $bd_id ($ref): gh pr view failed, skipping" >&2; skipped_count=$((skipped_count + 1)); continue; }
    state="$(echo "$json" | jq -r '.state')"
    case "$state" in
      MERGED)
        sha="$(echo "$json" | jq -r '.mergeCommit.oid // empty' | cut -c1-7)"
        reason="upstream merged${sha:+: $sha}"
        ;;
      CLOSED)
        reason="upstream closed (not merged)"
        ;;
      *)
        continue
        ;;
    esac
  else
    json="$(gh issue view "$num" --repo "$UPSTREAM" --json state,stateReason,url 2>/dev/null || true)"
    [[ -z "$json" ]] && { echo "  ? $bd_id ($ref): gh issue view failed, skipping" >&2; skipped_count=$((skipped_count + 1)); continue; }
    state="$(echo "$json" | jq -r '.state')"
    [[ "$state" != "CLOSED" ]] && continue
    state_reason="$(echo "$json" | jq -r '.stateReason // empty')"
    if [[ -n "$state_reason" && "$state_reason" != "null" ]]; then
      reason="upstream closed: ${state_reason,,}"
    else
      reason="upstream closed"
    fi
  fi

  if [[ "$DRY_RUN" == 1 ]]; then
    echo "  ✓ $bd_id ($ref): would close — $reason"
  else
    bd close "$bd_id" --reason="$reason" >/dev/null
    tri_log_note "$bd_id" "tri-sync: closed ($reason)"
    echo "  ✓ $bd_id ($ref): closed — $reason"
  fi
  closed_count=$((closed_count + 1))
done < <(list_open_with_refs)

if [[ "$DRY_RUN" == 1 ]]; then
  echo "DRY-RUN: would close $closed_count item(s); skipped $skipped_count; checked $processed"
else
  echo "Closed $closed_count item(s); skipped $skipped_count; checked $processed"
fi
