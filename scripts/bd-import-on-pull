#!/usr/bin/env bash
# bd-import-on-pull — retired JSONL-through-git sync fallback.
#
# mybd now syncs issue state through the configured Dolt remote
# (git+https://github.com/maphew/mybd.git). .beads/issues.jsonl may remain
# committed for export, backup, or viewer workflows, but it is not the
# cross-machine source of truth and should not be auto-imported after git pull.

set -euo pipefail

exit 0
