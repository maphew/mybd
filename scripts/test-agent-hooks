#!/usr/bin/env bash
# test-agent-hooks - verify the canonical, cross-platform agent hook configs.
#
# Usage: scripts/test-agent-hooks
#
# Exits non-zero if any check fails (unlike the warn-only session-close-check
# style this borrows structure from). Three groups:
#   1. Config schema - .codex/hooks.json and .claude/settings.json parse as
#      JSON; .codex/hooks.json carries all four bd codex-hook lifecycle
#      events, and SessionStart also fires the session-start-stamp hook.
#   2. Cross-platform command resolution - no Windows-only paths/binaries in
#      either hooks config, and every command referencing a repo script uses
#      an explicit shell compatible with that script.
#   3. session-start-stamp TTL behavior, exercised in a throwaway temp repo.
set -uo pipefail

root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$root"

CODEX_HOOKS="$root/.codex/hooks.json"
CLAUDE_SETTINGS="$root/.claude/settings.json"
STAMP_SCRIPT="$root/scripts/session-start-stamp"

fails=0
pass() { printf 'PASS: %s\n' "$*"; }
fail() { printf 'FAIL: %s\n' "$*" >&2; fails=$((fails + 1)); }

command -v jq >/dev/null 2>&1 || { echo "test-agent-hooks: jq is required" >&2; exit 2; }

# --- Group 1: config schema -------------------------------------------------

if jq empty "$CODEX_HOOKS" >/dev/null 2>&1; then
  pass "$CODEX_HOOKS parses as JSON"
else
  fail "$CODEX_HOOKS does not parse as JSON"
fi

if jq empty "$CLAUDE_SETTINGS" >/dev/null 2>&1; then
  pass "$CLAUDE_SETTINGS parses as JSON"
else
  fail "$CLAUDE_SETTINGS does not parse as JSON"
fi

# event_has_command <event> <regex> - true if any hook command under
# .hooks[event][].hooks[] matches regex.
event_has_command() {
  local event="$1" pattern="$2"
  jq -e --arg event "$event" --arg pattern "$pattern" '
    (.hooks[$event] // []) as $entries
    | any($entries[]; (.hooks // [])[]? | (.command // "") | test($pattern))
  ' "$CODEX_HOOKS" >/dev/null 2>&1
}

for event in SessionStart PreCompact PostCompact UserPromptSubmit; do
  if event_has_command "$event" "^bd codex-hook ${event}\$"; then
    pass "$CODEX_HOOKS: $event fires bd codex-hook $event"
  else
    fail "$CODEX_HOOKS: $event is missing a 'bd codex-hook $event' command"
  fi
done

if event_has_command "SessionStart" "session-start-stamp"; then
  pass "$CODEX_HOOKS: SessionStart also fires the session-start-stamp hook"
else
  fail "$CODEX_HOOKS: SessionStart is missing the session-start-stamp hook"
fi

# --- Group 2: cross-platform command resolution -----------------------------

for file in "$CODEX_HOOKS" "$CLAUDE_SETTINGS"; do
  if grep -qE '[A-Z]:\\' "$file"; then
    fail "$file: contains a drive-letter path (e.g. C:\\...)"
  else
    pass "$file: no drive-letter paths"
  fi

  if grep -qi 'bash\.exe' "$file"; then
    fail "$file: contains a bash.exe reference"
  else
    pass "$file: no bash.exe reference"
  fi

  if grep -qi 'PROGRA~1' "$file"; then
    fail "$file: contains a PROGRA~1 short-path reference"
  else
    pass "$file: no PROGRA~1 short-path reference"
  fi

  # Every command that references a repo script (session-start-stamp is the
  # only one currently invoked from these configs) must use `bash <script>` or
  # `bash -c ...`: session-start-stamp uses Bash syntax and cannot run under
  # POSIX sh on Linux.
  bad_commands="$(
    jq -r '
      [.. | objects | .command? // empty]
      | .[]
      | select(test("scripts/") or test("session-start-stamp"))
      | select((startswith("bash ") or startswith("bash -c")) | not)
    ' "$file" 2>/dev/null
  )"
  if [[ -z "$bad_commands" ]]; then
    pass "$file: every repo-script command uses bash <script> or bash -c form"
  else
    while IFS= read -r cmd; do
      [[ -n "$cmd" ]] && fail "$file: repo-script command not in 'bash' form: $cmd"
    done <<<"$bad_commands"
  fi
done

# --- Group 3: Beads hook wrapper portability -------------------------------

for hook in "$root/.githooks/pre-commit" "$root/.githooks/pre-push" "$root/.githooks/prepare-commit-msg"; do
  hook_name="${hook##*/}"
  for required in 'command -v timeout' 'command -v gtimeout' "perl -e 'alarm shift; exec @ARGV'" '_bd_used_perl=1' 'running without timeout' '[ $_bd_used_perl -eq 1 ] && [ $_bd_exit -eq 142 ]'; do
    if grep -Fq "$required" "$hook"; then
      pass "$hook_name: preserves Beads portable timeout fallback: $required"
    else
      fail "$hook_name: missing Beads portable timeout fallback: $required"
    fi
  done
done

# --- Group 4: session-start-stamp TTL behavior ------------------------------

if [[ ! -x "$STAMP_SCRIPT" && ! -r "$STAMP_SCRIPT" ]]; then
  fail "session-start-stamp not found at $STAMP_SCRIPT"
else
  tmpdir="$(mktemp -d)"
  cleanup_tmpdir() { rm -rf "$tmpdir"; }
  trap cleanup_tmpdir EXIT

  (
    cd "$tmpdir" || exit 1
    git init -q .
    mkdir -p .beads
  )
  stamp="$tmpdir/.beads/.session-start"

  # a) no stamp -> running the script creates one.
  if [[ -f "$stamp" ]]; then
    fail "stamp TTL setup: unexpected pre-existing stamp"
  else
    (cd "$tmpdir" && bash "$STAMP_SCRIPT") >/dev/null 2>&1
    if [[ -f "$stamp" ]]; then
      pass "stamp TTL: no stamp -> script creates one"
    else
      fail "stamp TTL: no stamp -> script did not create one"
    fi
  fi

  # b) fresh stamp (now) -> running again does NOT overwrite.
  now_iso="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
  printf '%s\tfakesha-fresh\n' "$now_iso" >"$stamp"
  before="$(cat "$stamp")"
  (cd "$tmpdir" && bash "$STAMP_SCRIPT") >/dev/null 2>&1
  after="$(cat "$stamp")"
  if [[ "$before" == "$after" ]]; then
    pass "stamp TTL: fresh stamp is not overwritten"
  else
    fail "stamp TTL: fresh stamp was overwritten (before=[$before] after=[$after])"
  fi

  # c) stale stamp (older than default TTL, 5h back) -> overwritten.
  stale_epoch=$(( $(date -u +%s) - 5 * 3600 ))
  stale_iso="$(date -u -d "@${stale_epoch}" +%Y-%m-%dT%H:%M:%SZ)"
  printf '%s\tfakesha-stale\n' "$stale_iso" >"$stamp"
  before="$(cat "$stamp")"
  (cd "$tmpdir" && bash "$STAMP_SCRIPT") >/dev/null 2>&1
  after="$(cat "$stamp")"
  if [[ "$before" != "$after" ]]; then
    pass "stamp TTL: stale stamp (5h, default TTL) is overwritten"
  else
    fail "stamp TTL: stale stamp (5h, default TTL) was NOT overwritten (still [$after])"
  fi

  # d) MYBD_SESSION_STAMP_TTL=1 with a 2-second-old stamp -> overwritten.
  recent_epoch=$(( $(date -u +%s) - 2 ))
  recent_iso="$(date -u -d "@${recent_epoch}" +%Y-%m-%dT%H:%M:%SZ)"
  printf '%s\tfakesha-recent\n' "$recent_iso" >"$stamp"
  before="$(cat "$stamp")"
  (cd "$tmpdir" && MYBD_SESSION_STAMP_TTL=1 bash "$STAMP_SCRIPT") >/dev/null 2>&1
  after="$(cat "$stamp")"
  if [[ "$before" != "$after" ]]; then
    pass "stamp TTL: MYBD_SESSION_STAMP_TTL=1 overwrites a 2s-old stamp"
  else
    fail "stamp TTL: MYBD_SESSION_STAMP_TTL=1 did NOT overwrite a 2s-old stamp (still [$after])"
  fi

  trap - EXIT
  cleanup_tmpdir
fi

# --- Summary -----------------------------------------------------------------

if [[ "$fails" -eq 0 ]]; then
  echo "test-agent-hooks: all checks passed"
  exit 0
else
  echo "test-agent-hooks: $fails check(s) failed"
  exit 1
fi
